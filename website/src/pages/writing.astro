---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { parseRssItems } from '../lib/parseRss';

let rssItems: ReturnType<typeof parseRssItems> = [];
if (siteConfig.kitNewsletterRss) {
  try {
    const res = await fetch(siteConfig.kitNewsletterRss);
    if (res.ok) {
      rssItems = parseRssItems(await res.text());
    }
  } catch {
    rssItems = [];
  }
}
---

<BaseLayout
  title="Writing — Alejandro Berrizbeitia"
  description="The Intelligence Layer newsletter and long-form essays."
>
  <main class="mx-auto max-w-2xl px-6 py-14 md:py-20">
    <h1 class="font-serif text-3xl font-semibold text-midnight dark:text-silver">Writing</h1>
    <p class="mt-4 leading-relaxed text-ink-muted dark:text-silver">
      <cite class="not-italic">The Intelligence Layer</cite> is the newsletter named in the narrative
      canon. Issues listed below load at build time when <code
        class="rounded bg-silver/25 px-1 py-0.5 text-sm text-midnight dark:text-ink-dark"
        >PUBLIC_KIT_NEWSLETTER_RSS</code
      > is set (for example in Cloudflare Pages). Long-form essays will ship as MDX in this repo when
      ready; see <code class="rounded bg-silver/25 px-1 py-0.5 text-sm text-midnight dark:text-ink-dark"
        >website/README.md</code
      > for the planned content-collection layout.
    </p>

    {
      siteConfig.kitNewsletterUrl && (
        <p class="mt-4">
          <a
            href={siteConfig.kitNewsletterUrl}
            class="font-medium text-midnight underline decoration-silver decoration-2 underline-offset-4 dark:text-silver"
          >
            Newsletter on Kit →
          </a>
        </p>
      )
    }

    <section class="mt-14">
      <h2 class="font-serif text-xl font-semibold text-midnight dark:text-silver">Newsletter issues</h2>
      {
        rssItems.length === 0 ? (
          <p class="mt-3 text-ink-muted dark:text-silver">
            {siteConfig.kitNewsletterRss
              ? 'RSS URL is set but no items were parsed, or the fetch failed during build.'
              : 'No RSS URL configured yet. Set PUBLIC_KIT_NEWSLETTER_RSS for production builds to list issues here.'}
          </p>
        ) : (
          <ol class="mt-4 list-decimal space-y-2 pl-5 text-ink-muted marker:text-midnight dark:text-silver dark:marker:text-silver">
            {rssItems.map((item) => (
              <li>
                <a href={item.link} class="text-midnight underline hover:text-midnight/80 dark:text-silver">
                  {item.title}
                </a>
                {item.pubDate && <span class="ml-2 text-sm text-ink-muted">({item.pubDate})</span>}
              </li>
            ))}
          </ol>
        )
      }
    </section>

    <section class="mt-14">
      <h2 class="font-serif text-xl font-semibold text-midnight dark:text-silver">Essays</h2>
      <p class="mt-3 text-ink-muted dark:text-silver">No long-form essays published on this domain yet.</p>
    </section>
  </main>
</BaseLayout>
