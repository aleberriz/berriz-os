---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { parseRssItems } from '../lib/parseRss';

let rssItems: ReturnType<typeof parseRssItems> = [];
if (siteConfig.kitNewsletterRss) {
  try {
    const res = await fetch(siteConfig.kitNewsletterRss);
    if (res.ok) {
      rssItems = parseRssItems(await res.text());
    }
  } catch {
    rssItems = [];
  }
}
---

<BaseLayout
  title="Writing — Alejandro Berrizbeitia"
  description="The Intelligence Layer newsletter and long-form essays."
>
  <main class="mx-auto max-w-2xl px-6 py-14 md:py-20">
    <h1 class="font-serif text-3xl font-semibold text-midnight dark:text-silver">Writing</h1>
    <p class="mt-4 leading-relaxed text-ink-muted dark:text-silver">
      <cite class="not-italic font-medium">The Intelligence Layer</cite> is a newsletter on semantic
      layers, causal inference, and AI-native analytics. Essays and longer pieces publish here when ready.
    </p>

    {
      siteConfig.kitNewsletterUrl && (
        <p class="mt-4">
          <a
            href={siteConfig.kitNewsletterUrl}
            class="font-medium text-midnight underline decoration-silver decoration-2 underline-offset-4 dark:text-silver"
          >
            Subscribe to the newsletter →
          </a>
        </p>
      )
    }

    {
      rssItems.length > 0 && (
        <section class="mt-14">
          <h2 class="font-serif text-xl font-semibold text-midnight dark:text-silver">
            Recent issues
          </h2>
          <ol class="mt-4 list-decimal space-y-2 pl-5 text-ink-muted marker:text-midnight dark:text-silver dark:marker:text-silver">
            {rssItems.map((item) => (
              <li>
                <a
                  href={item.link}
                  class="text-midnight underline hover:text-midnight/80 dark:text-silver"
                >
                  {item.title}
                </a>
                {item.pubDate && (
                  <span class="ml-2 text-sm text-ink-muted">
                    ({new Date(item.pubDate).toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })})
                  </span>
                )}
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </main>
</BaseLayout>
