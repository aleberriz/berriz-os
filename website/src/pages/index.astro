---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Alejandro Berrizbeitia">
  <main class="mx-auto max-w-2xl px-6 py-16 md:py-24">
    <p class="font-serif text-2xl font-semibold text-midnight dark:text-silver md:text-3xl">
      Narratives in numbers.
    </p>
    <p class="mt-6 text-lg leading-relaxed text-ink-muted dark:text-silver">
      Public hub scaffold (Astro + MDX + Tailwind). Copy for this site comes from
      <code class="rounded bg-silver/30 px-1.5 py-0.5 text-sm text-midnight dark:text-ink-dark"
        >brand/narrative.md</code
      >
      in berriz-os; Phase 2 will flesh out pages and deploy to Cloudflare Pages.
    </p>
  </main>
</BaseLayout>
