---
const pathname = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/building/', label: 'Building' },
  { href: '/writing/', label: 'Writing' },
  { href: '/about/', label: 'About' },
] as const;

function active(href: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href.replace(/\/$/, ''));
}
---

<header class="border-b border-silver/40 dark:border-silver/20">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-6 px-6 py-4">
    <a
      href="/"
      class="font-serif text-lg font-semibold tracking-tight text-midnight dark:text-silver"
    >
      Alejandro Berrizbeitia
    </a>
    <nav class="flex flex-wrap justify-end gap-x-5 gap-y-1 text-sm font-medium">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'transition-colors',
              active(href)
                ? 'text-midnight dark:text-ink-dark'
                : 'text-ink-muted hover:text-midnight dark:text-silver dark:hover:text-ink-dark',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
